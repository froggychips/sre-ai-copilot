# SRE AI Copilot Configuration

# Gemini API Key (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Discord Configuration
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
DISCORD_BOT_TOKEN=your_bot_token_if_using_client

# Kubernetes Settings
K8S_CONTEXT=gke_project_zone_cluster
SAFE_MODE=true
APPROVAL_REQUIRED=true

# FastAPI Settings
API_DEBUG=false
PORT=8000
